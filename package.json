{
  "name": "presentatool",
  "version": "0.1.10",
  "description": "Cross-platform presentation manager with remote clicker, LAN sync, and versioning",
  "main": "dist/main/main/index.js",
  "author": "taamrove",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n main,renderer,companion \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:companion\"",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev:renderer": "vite",
    "dev:companion": "vite --config vite.companion.config.ts",
    "build": "npm run build:main && npm run build:renderer && npm run build:companion",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:companion": "vite build --config vite.companion.config.ts",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "package:mac": "npm run build && electron-builder --mac",
    "release": "npm run build && electron-builder --mac --win --publish always",
    "release:draft": "npm run build && electron-builder --mac --win --publish always -c.releaseType=draft",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "node --test --experimental-strip-types src/**/*.test.ts"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "qrcode": "^1.5.4",
    "semver": "^7.8.1",
    "ws": "^8.16.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.5.10",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.57.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  },
  "build": {
    "appId": "as.trv.presentatool",
    "productName": "Presentatool",
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "publish": {
      "provider": "github",
      "owner": "taamrove",
      "repo": "presentatool"
    }
  }
}
